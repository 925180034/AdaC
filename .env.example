# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8080

# ===== 数据 =====
DATABASE_URL=sqlite:///data/metadata.db
DATA_DIR=./data
CKPT_PATH=./data/ckpt.db
ARTIFACTS_DIR=./data/artifacts

# ===== 向量存储 =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_TABLES=tbl_embeddings
QDRANT_COLLECTION_COLUMNS=col_embeddings

# ===== LLM =====
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3.5:9b
LLM_TIMEOUT=30

# ===== SBERT =====
SBERT_MODEL=sentence-transformers/all-MiniLM-L6-v2
SBERT_DEVICE=cuda:0
SBERT_BATCH_SIZE=256

# ===== TLCF =====
TLCF_L1_THRESHOLD=0.20
TLCF_L2_TOPK=40
TLCF_L3_TOPK=10
TLCF_WEIGHTS_JOIN=0.2,0.3,0.5
TLCF_WEIGHTS_UNION=0.4,0.4,0.2

# ===== Matcher =====
MATCH_WEIGHTS_SMD=0.6,0.4,0.0
MATCH_WEIGHTS_SSD=0.5,0.3,0.2
MATCH_WEIGHTS_SLD=0.4,0.2,0.4
MATCH_DECISION_THRESHOLD=0.7
MATCH_LLM_TOPN=10

# ===== 多租户 =====
DEFAULT_TENANT_ID=default

# ===== API Key 认证（M3） =====
# API_KEYS=key1,key2
